<h1>採点結果編集</h1>

<%= form_with model: @karaoke_score do |f| %>
  <div>
    <%= f.label :score_image, "採点画像" %>
    <%= f.file_field :score_image %>
  </div>

  <div>
    <%= f.label :song_id, "曲" %>
    <%= f.collection_select :song_id, Song.all, :id, :title %>
  </div>

  <div>
    <%= f.label :score, "点数" %>
    <%= f.number_field :score, step: 0.001, min: 0, max: 100 %>
  </div>

  <div>
    <%= f.label :sung_at, "歌唱日" %>
    <%= f.date_field :sung_at %>
  </div>

  <div>
    <%= f.label :memo, "メモ" %>
    <%= f.text_area :memo %>
  </div>

  <%= f.submit "更新" %>
<% end %>
